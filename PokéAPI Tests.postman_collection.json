      "name": "Pikachu",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", () => {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "pm.test(\"Le nom du Pokémon est bien Pikachu\", () => {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.name).to.eql(\"pikachu\");\r",
              "    pm.expect(jsonData.id).to.eql(25);\r",
              "});\r",
              "pm.test(\"Le Pokémon possède un tableau de types\", () => {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.types).to.be.an(\"array\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "https://pokeapi.co/api/v2/pokemon/25",
